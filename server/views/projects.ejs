<%#Import the header%>
<%- include('templates/header'); -%>
<%#/Import the header%>

<section class="projects">
  <div class="projects-container">
  <div class="projects-masthead">
    <h1>Harry and Hermione Projects</h1>
    <time>2020 — 2026</time>
  </div>

  <section class="projects-hero">
    <div>
      <h2>The Projects<br>of Harry and Hermione</h2>
      <p class="projects-hero-text">Below is the comprehensive list of projects that have been undertaken within the Harry and Hermione fandom over the course of the past decade or so.</p>
    </div>

  </section>

    <%# Projects List Loop %>
    <% projectslist.forEach(function(projects) { %>




    <section class="projects-quote-section">
    <blockquote>
      <%= projects.title %>
    </blockquote>
  </section>


  <section class="projects-body-content">
    <div class="projects-section-label"><%= projects.title %></div>
    <div class="projects-body-text">
        <p><%= projects.summary %></p>
        <a href="/projects/<%= projects.shortname %>" class="btn btn-primary">View Project</a>
    </div>
  <section class="projects-featured">
    <div class="projects-image-placeholder">
      <img src="<%= projects.image %>" alt="Spatial composition study">
    </div>
    <p class="projects-caption">Artwork by — <%= projects.artwork %></p>
  </section>
  </section>
    <%  }); %>
    <%# / Projects List Loop %>


  <div class="projects-footer">
    <p>Continue reading in Issue 05</p>
    <p>thequarterly.com</p>
  </div>
</div>
</section>





<%#Import the footer%>
<%- include('templates/footer'); -%>
<%#/Import the footer%>