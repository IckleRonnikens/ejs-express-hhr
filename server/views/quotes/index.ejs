    <div class="quotes-grid-image">
                <img src="./images/quotes/ootp.jpg" class="img-fluid w-100" alt="Order of the Phoenix">
    </div>
    <div class="quotes-grid-image">
                <img src="./images/quotes/hbp.jpg" class="img-fluid w-100" alt="Half-Blood Prince">
    </div>
    <div class="quotes-grid-image">
                <img src="./images/quotes/dh.jpg" class="img-fluid w-100" alt="Deathly Hallows">
    </div>
