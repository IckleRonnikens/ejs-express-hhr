<%#Import the header%>
<%- include('templates/header'); -%>
<%#/Import the header%>

<%# Blogs List Loop %>
<% bloglist.slice(-1).forEach(function(blog) { %>
<section class="blog">
<div class="blog-container">
  <div class="blog-masthead">
    <h1>Featured Blog Post</h1>
    <time><%= blog.date %></time>
  </div>

  <section class="blog-hero">
    <div>
      <h2><%= blog.title %></h2>
      <p class="blog-hero-text"><%= blog.summary %></p>
    <div class="blog-hero-meta">
      <p>By <%= blog.author %></p>
      <p>Image by <%= blog.artwork %></p>

      <a href="/blog/<%= blog.shortname %>"><button class="btn btn-light btn-lg">Read More</button></a>

    </div>
    </div>

  <section class="blog-featured">
    <div class="blog-image-placeholder">
      <img src="<%= blog.image %>" alt="Spatial composition study">
    </div>
    <p class="blog-caption">Figure 01 — Spatial composition study, 2025</p>
  </section>

  </section>
<%  }); %>
<%# / Blogs List Loop %>

  <section class="blog-quote-section">
    <blockquote>
     Blog Posts
    </blockquote>
  </section>


  <section class="blog-image-grid">
  <%# Blogs List Loop %>
  <% bloglist.reverse().splice(1).forEach(function(blog) { %>
    <div class="blog-grid-image">
        <a href="/blog/<%= blog.shortname %>">
          <img class="w-100" src="<%= blog.image %>" alt="<%= blog.shortname %>">
        </a>
    </div>
  <%  }); %>
  <%# / Blogs List Loop %>
  </section>

  <div class="blog-footer">
    <p>Continue reading in Issue 05</p>
    <p>thequarterly.com</p>
  </div>

</div>
</section>





<%#Import the footer%>
<%- include('templates/footer'); -%>
<%#/Import the footer%>