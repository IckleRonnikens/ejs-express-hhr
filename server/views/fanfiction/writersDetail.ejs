<%# Import the header%>
<%- include('../templates/header'); -%>
<%# /Import the header%>

<section class="writersdetails" id="writersdetails">
      <%# Writers Details %>

      <div class="row">
        <div class="col-lg-6">
          <div class="container" >

          <h1 ><%= writers.name %></h1><hr>
        </div>
        </div>
        <div class="col-lg-6">
                <a href="./<%= writers.shortname %>">
                  <img class="w-100 mb-1 " src="/images/writers/<%= writers.shortname %>.jpg" alt="Photo of <%= writers.title %>">
                </a>
        </div>
      </div>

          <div class="container" >

            <div class="row">
              <div class="col-sm-3 my-3">
                <a href="./<%= writers.shortname %>">
                  <img class="w-100 mb-1 " src="/images/writers/<%= writers.shortname %>.jpg" alt="Photo of <%= writers.title %>">
                </a>

              </div>

              <div class="col-sm-6 my-3">
                <p><%- writers.summary %></p>
                <p><%- writers.description %></p><br />      

              </div>
          
              <div class="col-sm-3 my-3">
                <h3>Recent Stories</h3><hr />
                <div class="row">
                <%# Stories %>
                <% if (stories.reverse().length > 0) { %>
                  <%for (i=0; i < stories.length; i ++){ %>
                      <div class="col-6">
                        <div class="pixgrid clearfix zoom">
                          <a href="/stories/<%= stories[i] %>"><img class="w-100" src="/images/stories/<%= stories[i] %>_tn.jpg"></a>
                          </div>
                      </div>
  
                  <%}%>
                <% }  %>
              <%# /Stories %>
            </div>
              </div>
        
        </div>
          </section>


      <%# /Writers Details %>


        
<%# Import the footer %>
<%- include('../templates/footer'); -%>
<%# /Import the footer %>